# Kafka
# Docker:  kafka:29092
# Local:   localhost:9092
KAFKA_BOOTSTRAP_SERVERS=

KAFKA_TOPIC_RAW=raw-events
KAFKA_TOPIC_SCORED=scored-events

# PostgreSQL
# Docker:  postgresql+asyncpg://bank_user:bank_password@postgres:5432/bank_churn_db
# Local:   postgresql+asyncpg://bank_user:bank_password@localhost:5432/bank_churn_db
DATABASE_URL=

# MongoDB
# Docker:  mongodb://admin:admin_password@mongodb:27017/bank_churn?authSource=admin
# Local:   mongodb://admin:admin_password@localhost:27017/bank_churn?authSource=admin
MONGODB_URI=
MONGODB_DB=bank_churn

# Model
MODEL_PATH=models/churn_model.cbm
